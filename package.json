{
  "name": "wardayacode",
  "version": "0.1.2",
  "description": "AI-powered coding agent for the terminal. Multi-provider, full-featured.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "wardayacode": "dist/cli.js",
    "wdc": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ai": "^4.1.0",
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/openai": "^1.1.0",
    "@ai-sdk/google": "^1.1.0",
    "zod": "^3.22.4",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "chalk": "^5.3.0",
    "better-sqlite3": "^11.7.0",
    "conf": "^13.0.1",
    "glob": "^11.0.0",
    "minimatch": "^10.0.1",
    "diff-match-patch": "^1.0.5",
    "marked": "^14.1.0",
    "marked-terminal": "^7.2.0",
    "nanoid": "^5.0.7",
    "ora": "^8.1.0",
    "strip-ansi": "^7.1.0",
    "figures": "^6.1.0",
    "eventemitter3": "^5.0.1",
    "cosmiconfig": "^9.0.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/diff-match-patch": "^1.0.36",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.15.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "ink-testing-library": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "llm",
    "claude",
    "openai",
    "gemini",
    "terminal",
    "developer-tools"
  ],
  "author": "Wardaya Dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fawwazmw/wardayacode.git"
  }
}
